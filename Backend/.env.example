# Server Configuration
PORT=5000
CORS_ORIGIN=*

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/krishi-kisan

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Configuration (optional)
# Get your API key from Google AI Studio / Google Cloud Generative Language API
# NOTE: On backend, this is more secure than storing your API key in frontend.
# You can use either variable name below (both are supported by this app).
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_API_KEY=your_google_gemini_api_key_here
